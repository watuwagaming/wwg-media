<%
layout('../admin/layout')
%>

<h1 class="admin-page-title">USER MANAGEMENT</h1>

<div style="margin-bottom:20px;font-size:14px;color:var(--text-2)">
  <strong style="color:var(--text-1)"><%= users.length %></strong> registered members
</div>

<table class="admin-table">
  <thead>
    <tr>
      <th>User</th>
      <th>Email</th>
      <th>Role</th>
      <th>Status</th>
      <th>Joined</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% users.forEach(u => { %>
    <tr>
      <td>
        <div style="display:flex;align-items:center;gap:10px">
          <div style="width:32px;height:32px;border-radius:50%;background:var(--bg-hover);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--red);flex-shrink:0">
            <%= initial(u.display_name || u.username) %>
          </div>
          <div>
            <div style="font-weight:600;font-size:14px"><%= u.display_name || u.username %></div>
            <div style="font-size:12px;color:var(--text-3)">@<%= u.username %></div>
          </div>
        </div>
      </td>
      <td style="font-size:13px;color:var(--text-2)"><%= u.email %></td>
      <td>
        <span style="padding:2px 10px;border-radius:3px;font-size:11px;font-weight:700;font-family:var(--font-condensed);letter-spacing:1px;text-transform:uppercase;
          background:<%= u.role === 'admin' ? 'var(--red)' : u.role === 'writer' ? 'rgba(167,139,250,0.15)' : 'var(--bg-hover)' %>;
          color:<%= u.role === 'admin' ? '#fff' : u.role === 'writer' ? 'var(--purple)' : 'var(--text-3)' %>">
          <%= u.role %>
        </span>
      </td>
      <td>
        <span style="padding:2px 10px;border-radius:3px;font-size:11px;font-family:var(--font-condensed);font-weight:700;letter-spacing:1px;text-transform:uppercase;
          background:<%= u.is_active ? 'rgba(0,201,167,0.15)' : 'rgba(232,23,46,0.1)' %>;
          color:<%= u.is_active ? 'var(--teal)' : 'var(--red)' %>">
          <%= u.is_active ? 'Active' : 'Banned' %>
        </span>
      </td>
      <td style="font-size:12px;color:var(--text-3)"><%= formatDate(u.created_at) %></td>
      <td>
        <% if (u.id !== user.id) { %>
        <div style="display:flex;gap:6px;flex-wrap:wrap">
          <!-- Role Change -->
          <form action="/admin/users/<%= u.id %>/role" method="POST" style="display:inline">
            <select name="role" class="form-select" style="padding:5px 8px;font-size:12px;height:auto" onchange="this.form.submit()">
              <option value="member" <%= u.role === 'member' ? 'selected' : '' %>>Member</option>
              <option value="writer" <%= u.role === 'writer' ? 'selected' : '' %>>Writer</option>
              <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
            </select>
          </form>
          <!-- Ban/Unban -->
          <form action="/admin/users/<%= u.id %>/toggle" method="POST" style="display:inline">
            <button type="submit" class="btn btn-sm"
              style="background:<%= u.is_active ? 'rgba(232,23,46,0.1)' : 'rgba(0,201,167,0.1)' %>;color:<%= u.is_active ? 'var(--red)' : 'var(--teal)' %>;border:1px solid currentColor"
              data-confirm="<%= u.is_active ? 'Ban' : 'Unban' %> @<%= u.username %>?">
              <%= u.is_active ? 'Ban' : 'Unban' %>
            </button>
          </form>
        </div>
        <% } else { %>
          <span style="font-size:12px;color:var(--text-3)">That's you</span>
        <% } %>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
