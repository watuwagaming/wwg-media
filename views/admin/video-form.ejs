<%
layout('../admin/layout')
const isEdit = !!video
%>

<div style="max-width:600px">
  <h1 class="admin-page-title">ADD VIDEO</h1>

  <% if (error) { %>
    <div class="form-error"><%= error %></div>
  <% } %>

  <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:28px">
    <form action="/admin/videos/<%= isEdit ? video.id + '/edit' : 'new' %>" method="POST">

      <div class="form-group">
        <label class="form-label">Video Title *</label>
        <input class="form-input" type="text" name="title" value="<%= isEdit ? video.title : '' %>" placeholder="Enter video title" required>
      </div>

      <div class="form-group">
        <label class="form-label">YouTube URL *</label>
        <input class="form-input" type="text" name="youtube_url" value="<%= isEdit ? 'https://www.youtube.com/watch?v=' + video.youtube_id : '' %>"
          placeholder="https://www.youtube.com/watch?v=... or short link" required>
        <p style="font-size:12px;color:var(--text-3);margin-top:6px">Paste any YouTube URL format — full, short, or embed.</p>
      </div>

      <div class="form-group">
        <label class="form-label">Description</label>
        <textarea class="form-textarea" name="description" style="min-height:100px" placeholder="Brief description of the video..."><%= isEdit ? video.description : '' %></textarea>
      </div>

      <div class="form-group">
        <label class="form-label">Category</label>
        <select class="form-select" name="category">
          <option value="general" <%= !isEdit || video.category === 'general' ? 'selected' : '' %>>General</option>
          <option value="review" <%= isEdit && video.category === 'review' ? 'selected' : '' %>>Review</option>
          <option value="opinion" <%= isEdit && video.category === 'opinion' ? 'selected' : '' %>>Opinion</option>
          <option value="gameplay" <%= isEdit && video.category === 'gameplay' ? 'selected' : '' %>>Gameplay</option>
          <option value="esports" <%= isEdit && video.category === 'esports' ? 'selected' : '' %>>Esports</option>
          <option value="news" <%= isEdit && video.category === 'news' ? 'selected' : '' %>>News</option>
        </select>
      </div>

      <div style="display:flex;align-items:center;gap:10px;margin-bottom:24px">
        <input type="checkbox" name="featured" id="featured" value="1"
          <%= isEdit && video.featured ? 'checked' : '' %>
          style="width:16px;height:16px;accent-color:var(--red)">
        <label for="featured" style="font-size:14px;cursor:pointer">Feature on homepage</label>
      </div>

      <div style="display:flex;gap:10px">
        <button type="submit" class="btn btn-primary"><%= isEdit ? 'Update Video' : 'Add Video' %></button>
        <a href="/admin" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>
