<div style="min-height:calc(100vh - 160px);display:flex;align-items:center;justify-content:center;padding:40px 20px;text-align:center">
  <div>
    <div style="font-family:var(--font-display);font-size:120px;color:var(--crimson);line-height:1;opacity:0.3;margin-bottom:16px">404</div>
    <h1 style="font-family:var(--font-display);font-size:36px;letter-spacing:2px;margin-bottom:12px">LOST IN THE GAME</h1>
    <p style="color:var(--text-2);font-size:17px;max-width:400px;margin:0 auto 28px"><%= message %></p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      <a href="/" class="btn btn-primary">Back to Home</a>
      <a href="/articles" class="btn btn-outline">Browse Posts</a>
    </div>
  </div>
</div>
