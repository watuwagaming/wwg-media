<%
// Single article page
%>
<div class="container-sm" style="padding-top:40px;padding-bottom:60px">

  <!-- BREADCRUMB -->
  <div style="font-size:13px;color:var(--text-3);font-family:var(--font-condensed);margin-bottom:24px;display:flex;align-items:center;gap:8px">
    <a href="/" style="color:var(--text-3);transition:color 0.2s" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text-3)'">Home</a>
    <span>›</span>
    <a href="/articles" style="color:var(--text-3);transition:color 0.2s" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text-3)'">Articles</a>
    <% if (article.cat_name) { %>
      <span>›</span>
      <a href="/articles?category=<%= article.cat_slug %>" style="color:<%= article.cat_color %>"><%= article.cat_name %></a>
    <% } %>
  </div>

  <!-- CATEGORY -->
  <% if (article.cat_name) { %>
    <span class="cat-badge" style="background:<%= article.cat_color %>20;color:<%= article.cat_color %>;border:1px solid <%= article.cat_color %>40;margin-bottom:14px;display:inline-block">
      <%= article.cat_name %>
    </span>
  <% } %>

  <!-- TITLE -->
  <h1 class="article-title"><%= article.title %></h1>
  <p style="font-size:19px;color:var(--text-2);line-height:1.6;margin-bottom:20px"><%= article.excerpt %></p>

  <!-- META BAR -->
  <div class="article-meta-bar">
    <div class="author-chip">
      <div class="ava">
        <% if (article.author_avatar) { %><img src="<%= article.author_avatar %>" alt=""><% } else { %><%= initial(article.author_name) %><% } %>
      </div>
      <span style="font-weight:700;color:var(--text-1)"><%= article.author_name || 'Community Member' %></span>
    </div>
    <span>•</span>
    <span><%= formatDate(article.published_at) %></span>
    <span>•</span>
    <span>👁 <%= article.views %> views</span>
    <span style="margin-left:auto;display:flex;gap:10px">
      <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(article.title) %>&url=<%= encodeURIComponent('https://wwgmedia.co.ke/articles/' + article.slug) %>"
         target="_blank" style="color:var(--text-3);font-size:13px;transition:color 0.2s" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text-3)'">
        Share this
      </a>
    </span>
  </div>

  <!-- COVER IMAGE -->
  <% if (article.cover_image) { %>
  <div class="article-hero">
    <img src="<%= article.cover_image %>" alt="<%= article.title %>" style="width:100%;border-radius:6px;max-height:500px;object-fit:cover">
  </div>
  <% } %>

  <!-- ARTICLE BODY -->
  <div class="article-body">
    <%- article.body %>
  </div>

  <!-- REACTION BAR -->
  <div class="reaction-bar">
    <button
      id="like-btn"
      class="like-btn <%= userLiked ? 'liked' : '' %>"
      data-slug="<%= article.slug %>"
    >
      <svg viewBox="0 0 24 24" fill="<%= userLiked ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span class="like-count"><%= likesCount %></span>
      <span><%= userLiked ? 'Liked' : 'Like' %></span>
    </button>
    <span style="font-size:13px;color:var(--text-3)">
      <% if (!user) { %><a href="/sign-in" style="color:var(--red)">Sign in</a> to react<% } %>
    </span>
  </div>

  <!-- AUTHOR BIO -->
  <% if (article.author_bio) { %>
  <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:24px;margin:32px 0;display:flex;gap:16px;align-items:flex-start">
    <div class="ava" style="width:52px;height:52px;font-size:18px;flex-shrink:0">
      <% if (article.author_avatar) { %><img src="<%= article.author_avatar %>" alt=""><% } else { %><%= initial(article.author_name) %><% } %>
    </div>
    <div>
      <div style="font-family:var(--font-condensed);font-size:11px;letter-spacing:2px;color:var(--text-3);text-transform:uppercase;margin-bottom:4px">Written by</div>
      <div style="font-family:var(--font-condensed);font-size:18px;font-weight:700;margin-bottom:6px"><%= article.author_name %></div>
      <p style="font-size:14px;color:var(--text-2);line-height:1.6"><%= article.author_bio %></p>
    </div>
  </div>
  <% } %>

  <!-- MORE LIKE THIS -->
  <% if (related.length) { %>
  <div style="margin-top:48px">
    <h3 class="section-title" style="font-size:20px"><span>RELATED</span> ARTICLES</h3>
    <div class="card-grid">
      <% related.forEach(r => { %>
      <a href="/articles/<%= r.slug %>">
        <article class="article-card">
          <div class="card-thumb">
            <% if (r.cover_image) { %>
              <img src="<%= r.cover_image %>" alt="<%= r.title %>" loading="lazy">
            <% } else { %>
              <div class="card-thumb-placeholder">🎮</div>
            <% } %>
          </div>
          <div class="card-body">
            <% if (r.cat_name) { %><span class="cat-badge" style="background:<%= r.cat_color %>20;color:<%= r.cat_color %>"><%= r.cat_name %></span><% } %>
            <h3 class="card-title"><%= r.title %></h3>
          </div>
        </article>
      </a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- COMMENTS SECTION -->
  <div class="comments-section" id="comments">
    <h3 class="comments-title">DISCUSSION (<%= comments.length %>)</h3>

    <!-- COMMENT FORM -->
    <% if (user) { %>
    <form class="comment-form" action="/articles/<%= article.slug %>/comment" method="POST" style="margin-bottom:32px">
      <div style="display:flex;gap:12px;align-items:flex-start">
        <div class="comment-ava">
          <% if (user.avatar) { %><img src="<%= user.avatar %>" alt=""><% } else { %><%= initial(user.display_name) %><% } %>
        </div>
        <div style="flex:1">
          <textarea name="body" class="form-textarea" style="min-height:80px;border-radius:6px 6px 0 6px" placeholder="What do you think? Drop your thoughts below..." required></textarea>
          <div style="text-align:right;margin-top:8px">
            <button type="submit" class="btn btn-primary btn-sm">Reply</button>
          </div>
        </div>
      </div>
    </form>
    <% } else { %>
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:20px;text-align:center;margin-bottom:28px">
      <p style="color:var(--text-2);margin-bottom:12px">Join the conversation — sign in to reply</p>
      <a href="/sign-in?next=/articles/<%= article.slug %>#comments" class="btn btn-primary btn-sm">Sign In to Reply</a>
      <span style="margin:0 8px;color:var(--text-3)">or</span>
      <a href="/register" class="btn btn-outline btn-sm">Join WWG</a>
    </div>
    <% } %>

    <!-- COMMENTS LIST -->
    <% if (comments.length) { %>
      <% comments.forEach(c => { %>
      <div class="comment">
        <div class="comment-ava">
          <% if (c.avatar) { %><img src="<%= c.avatar %>" alt=""><% } else { %><%= initial(c.display_name) %><% } %>
        </div>
        <div style="flex:1">
          <div class="comment-meta">
            <strong><%= c.display_name || c.username %></strong>
            <span style="margin-left:8px"><%= timeAgo(c.created_at) %></span>
          </div>
          <div class="comment-body"><%= c.body %></div>
        </div>
      </div>
      <% }) %>
    <% } else { %>
      <div style="text-align:center;padding:40px;color:var(--text-3)">
        <p style="text-align:center;padding:40px;color:var(--text-3)">No replies yet — kick off the discussion!</p>
      </div>
    <% } %>
  </div>

</div>
