# ─── NGINX CONFIG FOR WWG MEDIA ───────────────────────────────────────────────
# Save to: /etc/nginx/sites-available/wwgmedia
# Then: sudo ln -s /etc/nginx/sites-available/wwgmedia /etc/nginx/sites-enabled/
# Then: sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name YOUR_DOMAIN_HERE www.YOUR_DOMAIN_HERE;
    # If no domain yet, use your VPS IP: server_name YOUR_VPS_IP;

    # Max upload size (for article cover images)
    client_max_body_size 10M;

    # Gzip compression
    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
    gzip_min_length 1000;

    # Proxy to Node.js app
    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Static files — serve directly via nginx (faster)
    location /css/ {
        alias /var/www/wwg-media/public/css/;
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }

    location /js/ {
        alias /var/www/wwg-media/public/js/;
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }

    location /img/ {
        alias /var/www/wwg-media/public/img/;
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }

    location /uploads/ {
        alias /var/www/wwg-media/uploads/;
        expires 7d;
        add_header Cache-Control "public, no-transform";
    }
}

# ─── HTTPS (uncomment after getting SSL with certbot) ─────────────────────────
# Run: sudo certbot --nginx -d yourdomain.com -d www.yourdomain.com

# server {
#     listen 443 ssl;
#     server_name YOUR_DOMAIN www.YOUR_DOMAIN;
#
#     ssl_certificate /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
#     ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;
#
#     ... (same location blocks as above)
